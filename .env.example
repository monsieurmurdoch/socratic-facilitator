# Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=replace-with-a-long-random-string

# Encryption (for LTI keys, Google tokens — separate from JWT_SECRET)
# ENCRYPTION_MASTER_KEY=replace-with-a-different-long-random-string

# OAuth State (for LTI/Google login flows — falls back to JWT_SECRET)
# OAUTH_STATE_SECRET=replace-with-another-random-string

# Database (DigitalOcean provides DATABASE_URL when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/socratic_facilitator

# Redis (optional, for scaling WebSockets across instances)
# REDIS_URL=redis://localhost:6379

# File Storage
STORAGE_PATH=./uploads

# AI — Primary (Claude for message generation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AI — Fast LLM (ChatJimmy via cj2api for low-latency analysis)
# Deploy cj2api to Cloudflare Workers: https://github.com/Leo2148/cj2api
# Then set the endpoint URL below.
FAST_LLM_ENABLED=true
FAST_LLM_ENDPOINT=https://your-worker-name.yourusername.workers.dev/v1
FAST_LLM_TIMEOUT_MS=3000
FAST_LLM_MODEL=jimmy

# Staleness Guard — max time to wait for ANY LLM response before fallback
STALENESS_GUARD_TIMEOUT_MS=5000

# Speech-to-Text (choose one)
# Deepgram (recommended for real-time streaming)
DEEPGRAM_API_KEY=your-deepgram-key

# AssemblyAI (alternative)
# ASSEMBLY_API_KEY=your-assembly-key

# Text-to-Speech — Priority: ElevenLabs → Piper → silent
# ElevenLabs (high quality, cloud — RECOMMENDED for Railway/cloud deploys)
# If set, ElevenLabs is used automatically. Falls back to Piper if API fails.
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Piper (local, free — only works if binary is installed on the machine)
# Not available on Railway by default. Use ElevenLabs for cloud deployments.
# PIPER_PATH=/app/piper/piper
# PIPER_MODEL_PATH=/app/piper/models/en_US-lessac-medium.onnx

# JaaS (Jitsi as a Service) — Video conferencing
# Sign up at https://jaas.8x8.vc for a free account
JAAS_APP_ID=vpaas-magic-cookie-your-id-here
# Private RSA key from JaaS dashboard (paste the full PEM key)
# JAAS_API_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...your-key...\n-----END RSA PRIVATE KEY-----
# Key ID from JaaS dashboard (shown when you create an API key)
# JAAS_KEY_ID=vpaas-magic-cookie-your-id/your-key-id

# Facilitation Settings
MAX_TALK_RATIO=0.15
MIN_MESSAGES_BETWEEN=3
SILENCE_TIMEOUT_MS=15000
