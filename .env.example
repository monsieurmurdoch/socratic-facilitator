# Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (DigitalOcean provides DATABASE_URL when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/socratic_facilitator

# Redis (optional, for scaling WebSockets across instances)
# REDIS_URL=redis://localhost:6379

# File Storage
STORAGE_PATH=./uploads

# AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Speech-to-Text (choose one)
# Deepgram (recommended for real-time streaming)
DEEPGRAM_API_KEY=your-deepgram-key

# AssemblyAI (alternative)
# ASSEMBLY_API_KEY=your-assembly-key

# Text-to-Speech (choose one)
# ElevenLabs (high quality, cloud)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Piper (local, free - configured in Dockerfile)
# PIPER_PATH=/app/piper/piper
# PIPER_MODEL_PATH=/app/piper/models/en_US-lessac-medium.onnx

# Jitsi Configuration (for video mode)
JITSI_DOMAIN=meet.jit.si
# For self-hosted: JITSI_DOMAIN=your-jitsi-domain.com

# Facilitation Settings
MAX_TALK_RATIO=0.15
MIN_MESSAGES_BETWEEN=3
SILENCE_TIMEOUT_MS=15000
