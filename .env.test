NODE_ENV=test
PORT=3000

# Local test database. Start with: npm run db:local:up
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socratic_facilitator_test

# Deterministic non-production secrets for local Jest runs.
JWT_SECRET=socratic-test-jwt-secret-change-before-prod
SESSION_ACCESS_SECRET=socratic-test-session-access-secret
ENCRYPTION_MASTER_KEY=socratic-test-encryption-secret
LMS_CREDENTIALS_SECRET=socratic-test-lms-secret
OAUTH_STATE_SECRET=socratic-test-oauth-state-secret

DEMO_TEACHER_LOGIN_ENABLED=true
DEMO_TEACHER_NAME=Demo Teacher
DEMO_TEACHER_EMAIL=teacher@socratic.local
DEMO_TEACHER_PASSWORD=plato-demo

# Keep network AI calls off in local tests unless a suite explicitly opts in.
ANTHROPIC_API_KEY=
FAST_LLM_ENABLED=false
