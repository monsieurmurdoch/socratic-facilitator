{
  "name": "socratic-facilitator",
  "version": "0.1.0",
  "description": "Multi-party Socratic conversation facilitator powered by AI",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "bot": "node server/jitsi-bot/run-bot.js",
    "bot:headful": "node server/jitsi-bot/run-bot.js --headful",
    "jitsi:start": "bash ./jitsi/setup.sh && cd .local/jitsi/docker-jitsi-meet && docker compose up -d",
    "jitsi:stop": "cd .local/jitsi/docker-jitsi-meet && docker compose down",
    "jitsi:logs": "cd .local/jitsi/docker-jitsi-meet && docker compose logs -f",
    "db:local:up": "docker compose -f docker-compose.local.yml up -d postgres",
    "db:local:down": "docker compose -f docker-compose.local.yml down",
    "db:local:logs": "docker compose -f docker-compose.local.yml logs -f postgres",
    "db:init": "node -e \"require('dotenv').config({ path: '.env.test' }); require('./server/db').initializeSchema().then(() => require('./server/db').end()).catch((err) => { console.error(err); process.exit(1); })\"",
    "setup": "bash ./jitsi/setup.sh && npm install",
    "local": "bash ./start-local.sh",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:review": "node scripts/run-human-review.mjs",
    "eval:facilitation": "node scripts/run-facilitation-eval.mjs",
    "smoke:jitsi-mute": "node scripts/smoke-jitsi-mute.cjs",
    "status:sync": "node scripts/sync-obsidian-status.mjs",
    "status:push-update": "node scripts/sync-obsidian-status.mjs --push-update",
    "hooks:install": "cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "puppeteer": "^24.37.5",
    "puppeteer-stream": "^3.0.22",
    "redis": "^5.11.0",
    "uuid": "^10.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
